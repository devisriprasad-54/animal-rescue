### Animal Rescue Network - API Test Requests
### Make sure backend is running: npm run dev
### Backend URL: http://localhost:5000

@baseUrl = http://localhost:5001
@contentType = application/json

### ============================================
### STEP 1: SIGNUP REQUESTS
### ============================================

### Regular User Signup
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "name": "John Doe",
  "email": "john@example.com",
  "password": "password123",
  "role": "user",
  "phone": "+1-555-0101",
  "address": "New York, NY"
}

### Volunteer Signup  
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "name": "Jane Volunteer",
  "email": "jane.volunteer@example.com",
  "password": "password123",
  "role": "volunteer",
  "phone": "+1-555-0102",
  "address": "Los Angeles, CA",
  "skills": ["First Aid", "Animal Handling", "Tracking"]
}

### NGO Signup
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "name": "Save Animals Foundation",
  "email": "ngo@saveanimals.com",
  "password": "password123",
  "role": "ngo",
  "ngoName": "Save Animals Foundation",
  "registrationNumber": "NGO-2024-001",
  "phone": "+1-555-0103",
  "address": "Chicago, IL"
}

### ============================================
### STEP 2: LOGIN REQUESTS (Get JWT Token)
### ============================================

### User Login
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "john@example.com",
  "password": "password123"
}

###
### Volunteer Login
POST {{baseUrl}}/api/auth/login  
Content-Type: {{contentType}}

{
  "email": "jane.volunteer@example.com",
  "password": "password123"
}

###
### NGO Login
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "ngo@saveanimals.com",
  "password": "password123"
}

### ============================================
### STEP 3: ANIMAL ENDPOINTS
### ============================================

### Get All Animals (No Auth Required)
GET {{baseUrl}}/api/animals

###
### Get Animals by Species
GET {{baseUrl}}/api/animals?species=Dog

###
### Get Available Animals for Adoption
GET {{baseUrl}}/api/animals?isAdopted=false

###
### Create Animal (NGO Only - Use JWT Token)
POST {{baseUrl}}/api/animals
Content-Type: {{contentType}}
Authorization: Bearer YOUR_JWT_TOKEN

{
  "name": "Bella",
  "species": "Dog",
  "breed": "Golden Retriever",
  "age": "2",
  "healthStatus": "Healthy",
  "rescueStory": "Found on streets, now ready for adoption",
  "images": []
}

###
### Get Specific Animal
GET {{baseUrl}}/api/animals/ANIMAL_ID

###
### Request Adoption
PUT {{baseUrl}}/api/animals/ANIMAL_ID/adopt
Authorization: Bearer YOUR_JWT_TOKEN

###
### Delete Animal (NGO Only - Must be the animal creator)
DELETE {{baseUrl}}/api/animals/ANIMAL_ID
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjZhMTNjOWNjMDBhMjJhNjFlZGE5NTFhOSIsImlhdCI6MTc3OTY4MTc3NywiZXhwIjoxNzgyMjczNzc3fQ.2l5Mv4JU7r76Z5ZdVK20o9QH4WozZgJTV_6nPtkor2A

### ============================================
### STEP 4: RESCUE REQUEST ENDPOINTS
### ============================================

### Get All Rescue Requests  
GET {{baseUrl}}/api/rescues

###
### Get Pending Rescues Only
GET {{baseUrl}}/api/rescues?status=pending

###
### Get Critical Rescues
GET {{baseUrl}}/api/rescues?emergencyLevel=critical

###
### Report New Rescue Emergency
POST {{baseUrl}}/api/rescues
Content-Type: {{contentType}}
Authorization: Bearer YOUR_JWT_TOKEN

{
  "animalType": "Dog",
  "location": "Main Street, Downtown",
  "description": "Injured dog found on the side of the road",
  "emergencyLevel": "critical",
  "images": []
}

###
### Add Update to Rescue
POST {{baseUrl}}/api/rescues/RESCUE_ID/updates
Content-Type: {{contentType}}
Authorization: Bearer YOUR_JWT_TOKEN

{
  "text": "Arrived at location. Animal is stable. Transporting to clinic."
}

###
### Update Rescue Status (NGO Only)
PUT {{baseUrl}}/api/rescues/RESCUE_ID
Content-Type: {{contentType}}
Authorization: Bearer YOUR_JWT_TOKEN

{
  "status": "assigned",
  "assignedVolunteer": "VOLUNTEER_ID"
}

###
### Close Rescue Request
PUT {{baseUrl}}/api/rescues/RESCUE_ID/close
Authorization: Bearer YOUR_JWT_TOKEN

### ============================================
### STEP 5: VOLUNTEER ENDPOINTS
### ============================================

### Get All Volunteers
GET {{baseUrl}}/api/volunteers

###
### Get Volunteer Dashboard (Requires Auth)
GET {{baseUrl}}/api/volunteers/dashboard
Authorization: Bearer YOUR_JWT_TOKEN

###
### Update Volunteer Profile
PUT {{baseUrl}}/api/volunteers/profile
Content-Type: {{contentType}}
Authorization: Bearer YOUR_JWT_TOKEN

{
  "skills": ["First Aid", "Animal Handling", "Tracking", "Rescue Operations"],
  "isAvailable": true,
  "phone": "+1-555-0102",
  "address": "Los Angeles, CA"
}

### ============================================
### STEP 6: NGO ENDPOINTS
### ============================================

### Get All NGOs
GET {{baseUrl}}/api/ngos

###
### Update NGO Profile  
PUT {{baseUrl}}/api/ngos/profile
Content-Type: {{contentType}}
Authorization: Bearer YOUR_JWT_TOKEN

{
  "ngoName": "Save Animals Foundation",
  "registrationNumber": "NGO-2024-001",
  "phone": "+1-555-0103",
  "address": "Chicago, IL"
}

